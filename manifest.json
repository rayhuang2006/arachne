{
  "manifest_version": 3,
  "name": "Arachne",
  "version": "0.1.0",
  "description": "Idle tabs grow spider webs.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
  ],
  "permissions": ["storage"]
}
